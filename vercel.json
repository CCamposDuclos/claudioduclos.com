{
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/projetos/:slug", "destination": "/project.html" }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.claudioduclos.com" }],
      "destination": "https://claudioduclos.com/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" }
      ]
    }
  ]
}
